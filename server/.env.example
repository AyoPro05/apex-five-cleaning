# Server Configuration
PORT=5001
NODE_ENV=development
# Development: http://localhost:5173
# Production: https://www.apexfivecleaning.co.uk (or your API URL if separate)
CLIENT_URL=http://localhost:3000

# Database
# Local: mongodb://localhost:27017/apex-cleaning
# Production (Render): MongoDB Atlas connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb://localhost:27017/apex-cleaning

# Email Service Configuration
# One sender config sends to ALL customer addresses (gmail, yahoo, corporate, etc.).
# You only configure YOUR outbound identity below; no per-recipient-domain setup.
# Choose one: 'sendgrid' or 'smtp'
EMAIL_PROVIDER=smtp

# SendGrid Email Service (if using SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=info@apexfivecleaning.co.uk

# SMTP Email Service — IONOS (apexfivecleaning.co.uk)
# UK host: smtp.ionos.co.uk | Port 587 (STARTTLS) or 465 (SSL)
# SMTP_USER and SMTP_FROM_EMAIL must be the same IONOS mailbox address
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=587
SMTP_USER=info@apexfivecleaning.co.uk
SMTP_PASS=your_ionos_mailbox_password
SMTP_FROM_NAME=Apex Five Cleaning
SMTP_FROM_EMAIL=info@apexfivecleaning.co.uk

# Email — single active mailbox (info@). Set all of these to the same address on Render.
NOTIFY_EMAIL=info@apexfivecleaning.co.uk
CUSTOMER_FROM_NAME=Apex Five Cleaning
CUSTOMER_FROM_EMAIL=info@apexfivecleaning.co.uk
COMPANY_EMAIL=info@apexfivecleaning.co.uk

# Quote Approved / Contact / Branding (used in all email templates)
COMPANY_PHONE=020 3535 6331
COMPANY_PHONE_TEL=+442035356331
COMPANY_NAME=Apex Five Cleaning
COMPANY_LEGAL_NAME=Apex Five Capital Ltd
COMPANY_TAGLINE=Professional Eco-Friendly Cleaning Services in UK
COMPANY_WEBSITE=https://www.apexfivecleaning.co.uk
COMPANY_ADDRESS=Wallington, Surrey, UK
# Logo URL for emails (must be publicly accessible; defaults to CLIENT_URL/apex-five-logo.png)
COMPANY_LOGO_URL=https://www.apexfivecleaning.co.uk/apex-five-logo.png

# Admin dashboard auth (token only — not an email address)
ADMIN_TOKEN=your_secure_admin_token_here

# JWT (required for auth – set in production)
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d
# Optional: dedicated HMAC secret for signed upload URLs (falls back to JWT_SECRET)
UPLOAD_SIGNING_SECRET=your_upload_signing_secret_here

# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Render (optional): platform sets RENDER_EXTERNAL_URL for this service — used for CORS if your frontend is on the same host.
# Optional comma-separated extra origins (preview deploys, etc.):
# ADDITIONAL_CORS_ORIGINS=https://branch--yoursite.onrender.com,https://preview.example.com

# Stripe (payments) - get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Required in production. Get from Stripe Dashboard → Developers → Webhooks → Add endpoint → Signing secret. Used to verify webhook signatures.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
